{
    "name": "oluokunkabiru/auto-seeder",
    "description": "Framework-agnostic PHP package that auto-seeds database tables by introspecting model schemas and generating realistic random data via Faker.",
    "type": "library",
    "license": "MIT",
    "keywords": ["laravel", "seeder", "database", "faker", "auto-seed", "testing"],
    "homepage": "https://github.com/oluokunkabiru/auto-seeder",
    "authors": [
        {
            "name": "OLUOKUN KABIRU ADESINA",
            "email": "oluokunkabiru2015@gmail.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0",
        "fakerphp/faker": "^1.23",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Oluokunkabiru\\AutoSeeder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oluokunkabiru\\AutoSeeder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oluokunkabiru\\AutoSeeder\\AutoSeederServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
