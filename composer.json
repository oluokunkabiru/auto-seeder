{
    "name": "oluokunkabiru/auto-seeder",
    "description": "Intelligent automated PHP database seeder for Laravel that introspects schema architectures to instantly populate precise Fake data natively adhering to Types, ENUM fields, and Foreign Key Constraints.",
    "keywords": ["laravel", "php", "seeder", "faker", "testing", "database-seeder", "auto-seeder", "livewire", "mock-data", "schema-introspection", "foreign-key-resolution", "dummy-data"],
    "type": "library",
    "license": "MIT",
    "homepage": "https://github.com/oluokunkabiru/auto-seeder",
    "authors": [
        {
            "name": "OLUOKUN KABIRU ADESINA",
            "email": "oluokunkabiru2015@gmail.com",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.0",
        "fakerphp/faker": "^1.23",
        "livewire/livewire": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Oluokunkabiru\\AutoSeeder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oluokunkabiru\\AutoSeeder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oluokunkabiru\\AutoSeeder\\AutoSeederServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    }
}
